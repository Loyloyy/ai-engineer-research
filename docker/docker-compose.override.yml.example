# Copy to docker-compose.override.yml (GITIGNORED) on the server for host-specific config.
# `docker compose` auto-merges it. Keep machine-specific paths/IPs/GPU settings ONLY here.
#
# Example: mount private local model weights (embeddings/reranker, M2+) read-only and point
# .env's AER_EMBEDDING / AER_RERANK_MODEL at the in-container path.

services:
  app:
    volumes:
      # - /path/to/models:/models:ro
      []
    # GPU access for in-process embedding/rerank (M2+), if needed:
    # deploy:
    #   resources:
    #     reservations:
    #       devices:
    #         - driver: nvidia
    #           count: 1
    #           capabilities: [gpu]

    # ---- OPTIONAL: Langfuse tracing (AER_TRACING=1) ----
    # Join the shared `depot-net` so the app resolves `langfuse-web:3000` (the Langfuse stack lives in
    # the `service-depot` repo). Listing networks here means you MUST also keep `default` (else the app
    # loses access to searxng). Bring depot up first: `depot up --app stage-2` (creates depot-net).
    # networks:
    #   - default
    #   - depot-net

# networks:
#   depot-net:
#     external: true
