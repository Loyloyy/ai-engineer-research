# ============================================================================
# ai-engineer-research — environment.  Copy to .env and fill in. .env is GITIGNORED.
#
# NO LiteLLM proxy. Each role binds its own endpoint+key+model directly via an
# in-process ChatOpenAI (see src/ai_engineer_research/models.py::build_chat_model).
# OpenAI-compatible covers BOTH on-prem vLLM and any frontier endpoint.
#
# ⚠️  This file is committed — keep it GENERIC. Put real served-model ids, hostnames,
#     IPs and keys ONLY in the gitignored .env you create on the server.
# ============================================================================

# ---- ROLES.  For each: <ROLE>_MODEL (served id) + <ROLE>_API_BASE + <ROLE>_API_KEY.
#   on-prem vLLM : MODEL=<served-model-id>   API_BASE=http://host.docker.internal:<port>/v1   API_KEY=not-needed
#                  (vLLM accepts any non-empty key. The served id may have a LEADING SLASH —
#                   check GET <API_BASE>/models -> data[0].id and use it EXACTLY.)
#   frontier     : MODEL=<provider/model>    API_BASE=https://openrouter.ai/api/v1            API_KEY=<key>
#   The app container reaches a host vLLM via host.docker.internal (compose extra_hosts).
#
# Roles: strategic = planner / lead reasoning · smart = writer / artifact extraction ·
#        fast = summarize / sub-tasks · judge = eval (pick a DIFFERENT family than the generator).
# ----------------------------------------------------------------------------

# strategic — planner / lead (must be a reliable multi-step TOOL caller; this is what M0 validates)
STRATEGIC_MODEL=<served-model-id>
STRATEGIC_API_BASE=http://host.docker.internal:<port>/v1
STRATEGIC_API_KEY=not-needed

# smart — report writer / structured-artifact extraction
SMART_MODEL=<served-model-id>
SMART_API_BASE=http://host.docker.internal:<port>/v1
SMART_API_KEY=not-needed

# fast — high-volume summarize / sub-tasks (smaller/cheaper model)
FAST_MODEL=<served-model-id>
FAST_API_BASE=http://host.docker.internal:<port>/v1
FAST_API_KEY=not-needed

# judge — eval only; DIFFERENT family than the generator
JUDGE_MODEL=<served-model-id>
JUDGE_API_BASE=http://host.docker.internal:<port>/v1
JUDGE_API_KEY=not-needed

# ---- M0 knob: which role the probe drives (default: strategic). ----
# Set LEAD_ROLE=strategic for the on-prem candidate; flip to a frontier-backed role to compare.
LEAD_ROLE=strategic

# ---- M2: multi-agent mode (lead delegates to code-scout/landscape/maturity subagents). ----
# Unset/0 = lean M1 single-agent loop. 1 = M2 multi-agent.
AER_MULTI_AGENT=0

# ---- Search (M1+) — SearXNG, reached by service name inside the compose network. ----
SEARX_URL=http://searxng:8080

# ---- GitHub API (M2 code-scout tools). Optional but STRONGLY recommended: a fine-grained PAT lifts
#      rate limits 60 -> 5000 req/hr and enables code search. Read-only/public scope is enough.
#      Machine-specific secret → lives ONLY here (gitignored), never in tracked files.
# GITHUB_TOKEN=

# ---- fetch_url backend (M1) ----
#   http    = httpx + trafilatura (no browser; robust on the egress allowlist) — the safe default.
#   browser = Crawl4AI + Playwright chromium (renders JS) — needs the chromium binary installed,
#             which needs the Playwright download CDN unblocked on the server egress allowlist.
#   auto    = browser if a chromium binary is present, else http (with http fallback on empty).
AER_FETCH_BACKEND=auto

# ---- Local embedding + reranker model paths (M2+, optional). ----
# Machine-specific/private paths go HERE (gitignored), never in tracked files.
# The embedding needs the huggingface: prefix; the reranker is a bare path.
# Requires mounting the path into the container — see docker/docker-compose.override.yml.
# AER_EMBEDDING=huggingface:/path/to/models/BAAI/bge-m3
# AER_RERANK_MODEL=/path/to/models/BAAI/bge-reranker-v2-m3
