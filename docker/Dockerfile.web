# Web UI image — the FastAPI control/presentation surface, serving the PREBUILT React SPA.
# No pipeline logic lives in the UI (CLAUDE.md rule #3) — it wraps the headless contract.
#
# WHY no node build here: the deploy server's egress blocks the npm registry (only GitHub/HF/PyPI/
# container registries are reachable), so `npm install` ECONNRESETs during a server-side build. The SPA
# is therefore built OFF-server (any box with npm + internet) and its `frontend/dist/` is committed to
# the repo; this image just copies + serves it. PyPI IS reachable, so the Python layer still builds here.
# Rebuild the SPA after any frontend change:  cd frontend && npm install && npm run build  (then commit dist).
FROM python:3.11-slim

ENV PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    HF_HOME=/app/.hf_cache \
    AER_UI_STATIC_DIR=/app/frontend/dist

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential git curl \
    && rm -rf /var/lib/apt/lists/*

# Deps first (better layer caching). web = fetch backend used by the core; obs = optional tracing;
# ui = fastapi/uvicorn/sse-starlette (this layer).
COPY pyproject.toml ./
COPY src ./src
RUN pip install --upgrade pip && pip install -e ".[web,obs,ui]"

# Runtime assets + the prebuilt SPA (built off-server; see header).
COPY config ./config
COPY frontend/dist ./frontend/dist

EXPOSE 8000
CMD ["uvicorn", "ai_engineer_research.webui.app:app", "--host", "0.0.0.0", "--port", "8000"]
